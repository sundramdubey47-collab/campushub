generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model University {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  city      String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  colleges  College[]
  notes     Note[]
}

model College {
  id           Int      @id @default(autoincrement())
  name         String
  code         String
  city         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  universityId Int
  university   University   @relation(fields: [universityId], references: [id])

  departments  Department[]
  students     User[]
  admin        User?   @relation("CollegeAdmin")
  notices Notice[]
  events Event[]
  listings Listing[]
  lostFoundItems LostFoundItem[]
  resourceRequests ResourceRequest[]
  rentalItems RentalItem[]
  tests Test[]
  timetableSlots TimetableSlot[]
  @@unique([universityId, code])
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collegeId Int
  college   College   @relation(fields: [collegeId], references: [id])

  courses   Course[]
  students  User[]
  notices Notice[]

  @@unique([collegeId, code])
}

model Course {
  id           Int      @id @default(autoincrement())
  name         String
  code         String
  durationYrs  Int      @default(4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  semesters    Semester[]
  students     User[]
  notes        Note[]
  notices Notice[]
  timetableSlots TimetableSlot[]
tests Test[]
  @@unique([departmentId, code])
}

model Semester {
  id        Int      @id @default(autoincrement())
  number    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id])

  subjects  Subject[]
  students  User[]
  notes     Note[]
  notices Notice[]
  tests Test[]
  timetableSlots TimetableSlot[]
  @@unique([courseId, number])
}

model Subject {
  id         Int      @id @default(autoincrement())
  name       String
  code       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  semesterId Int
  semester   Semester @relation(fields: [semesterId], references: [id])

  notes      Note[]
tests Test[]
  @@unique([semesterId, code])
}

enum UserRole {
  STUDENT
  FACULTY
  ADMIN
  SUPER_ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STUDENT)
  phone        String?  @unique
  emailVerified DateTime?
  phoneVerified Boolean  @default(false)
  avatarUrl    String?
  isPremium    Boolean  @default(false)
  premiumUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Student ke liye — kis college/dept/course/semester me hai
  collegeId    Int?
  college      College?    @relation(fields: [collegeId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  courseId     Int?
  course       Course?     @relation(fields: [courseId], references: [id])
  semesterId   Int?
  semester     Semester?   @relation(fields: [semesterId], references: [id])
  // Admin ke liye — sirf ek college manage karta hai
  managedCollegeId Int?    @unique
  managedCollege   College? @relation("CollegeAdmin", fields: [managedCollegeId], references: [id])
  referralCode String? @unique
  referredById Int?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")
  uploadedNotes Note[] @relation("UploadedNotes")
  ratings   Rating[]
  bookmarks Bookmark[]
  comments  Comment[]
  postedNotices Notice[] @relation("PostedNotices")
  createdEvents Event[] @relation("CreatedEvents")
  eventRegistrations EventRegistration[]
  sellerListings Listing[] @relation("SellerListings")
  wishlist       Wishlist[]
  sentMessages   ChatMessage[] @relation("SentMessages")
  buyerOrders    Order[] @relation("BuyerOrders")
  lostFoundItems LostFoundItem[]
  rentalItems    RentalItem[] @relation("RentalOwner")
  rentalBookings RentalBooking[] @relation("RentalRenter")
  payments Payment[]
  feedbacks Feedback[]
  reports Report[]
  resourceRequests ResourceRequest[] @relation("RequestedResources")
  lastSeenNotificationsAt DateTime?
  chatSessions ChatSession[]
  createdTests   Test[]
  testAttempts   TestAttempt[]
  testPurchases  TestPurchase[]
  coupons Coupon[]
  devices UserDevice[]
}

enum NoteCategory {
  NOTES
  ASSIGNMENT
  LAB_RECORD
  PREVIOUS_YEAR_PAPER
  BOOK
  PRESENTATION
  PRACTICAL_FILE
  QUESTION_BANK
  FACULTY_NOTES
  VIVA_QUESTIONS
  PROJECT
  SYLLABUS
  OTHERS
}
model Note {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  fileType    String
  category    NoteCategory @default(NOTES)
  unit        String?
  isPremium   Boolean  @default(false)

  views       Int      @default(0)
  downloads   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  uploadedById Int
  uploadedBy   User     @relation("UploadedNotes", fields: [uploadedById], references: [id])

  universityId Int
  university   University @relation(fields: [universityId], references: [id])

  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])

  semesterId  Int
  semester    Semester @relation(fields: [semesterId], references: [id])

  subjectId   Int?
  subject     Subject? @relation(fields: [subjectId], references: [id])
  ratings   Rating[]
  bookmarks Bookmark[]
  comments  Comment[]
  fulfillsRequests ResourceRequest[]
  coupons Coupon[]
}
model Coupon {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  discountPercent Int      @default(5)
  isUsed          Boolean  @default(false)
  usedAt          DateTime?
  createdAt       DateTime @default(now())

  ownerId         Int
  owner           User     @relation(fields: [ownerId], references: [id])

  sourceNoteId    Int?
  sourceNote      Note?    @relation(fields: [sourceNoteId], references: [id])
}
model Rating {
  id        Int      @id @default(autoincrement())
  value     Int
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  noteId    Int
  note      Note     @relation(fields: [noteId], references: [id])

  @@unique([userId, noteId])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  noteId    Int
  note      Note     @relation(fields: [noteId], references: [id])

  @@unique([userId, noteId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  noteId    Int
  note      Note     @relation(fields: [noteId], references: [id])
}
model Notice {
  id           Int       @id @default(autoincrement())
  title        String
  content      String
  attachmentUrl String?

  isPinned     Boolean   @default(false)
  isArchived   Boolean   @default(false)
  publishAt    DateTime  @default(now())

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  postedById   Int
  postedBy     User      @relation("PostedNotices", fields: [postedById], references: [id])

  collegeId    Int
  college      College   @relation(fields: [collegeId], references: [id])

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  courseId     Int?
  course       Course?   @relation(fields: [courseId], references: [id])

  semesterId   Int?
  semester     Semester? @relation(fields: [semesterId], references: [id])
}
enum EventType {
  FEST
  HACKATHON
  SEMINAR
  SPORTS
  WORKSHOP
  COMPETITION
  OTHER
}

model Event {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  type          EventType @default(OTHER)
  venue         String?
  bannerUrl     String?

  eventDate     DateTime
  endDate       DateTime?
  registrationDeadline DateTime?
  seatLimit     Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdById   Int
  createdBy     User      @relation("CreatedEvents", fields: [createdById], references: [id])

  collegeId     Int
  college       College   @relation(fields: [collegeId], references: [id])

  registrations EventRegistration[]
}

model EventRegistration {
  id          Int      @id @default(autoincrement())
  registeredAt DateTime @default(now())
  qrCode      String   @unique
  attended    Boolean  @default(false)

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  eventId     Int
  event       Event    @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}
enum ListingType {
  SELL
  EXCHANGE
}

enum ListingCategory {
  BOOKS
  LAPTOP
  CYCLE
  CALCULATOR
  FURNITURE
  HOSTEL_ITEMS
  ELECTRONICS
  OTHER
}

enum ListingStatus {
  AVAILABLE
  SOLD
  RESERVED
}

model Listing {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  category    ListingCategory
  type        ListingType     @default(SELL)
  price       Int?
  imageUrl    String?
  images ListingImage[]
  location    String?
  status      ListingStatus   @default(AVAILABLE)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sellerId    Int
  seller      User            @relation("SellerListings", fields: [sellerId], references: [id])

  collegeId   Int
  college     College         @relation(fields: [collegeId], references: [id])

  wishlistedBy Wishlist[]
  messages     ChatMessage[]
  orders       Order[]
}
model ListingImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  createdAt DateTime @default(now())

  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])

  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Order {
  id          Int      @id @default(autoincrement())
  finalPrice  Int?
  createdAt   DateTime @default(now())

  buyerId     Int
  buyer       User     @relation("BuyerOrders", fields: [buyerId], references: [id])

  listingId   Int
  listing     Listing  @relation(fields: [listingId], references: [id])
}
enum LostFoundType {
  LOST
  FOUND
}

model LostFoundItem {
  id            Int           @id @default(autoincrement())
  type          LostFoundType
  title         String
  description   String?
  imageUrl      String?
  location      String?
  contactNumber String?
  reward        String?
  isResolved    Boolean       @default(false)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  reportedById  Int
  reportedBy    User          @relation(fields: [reportedById], references: [id])

  collegeId     Int
  college       College       @relation(fields: [collegeId], references: [id])
}
enum RentalCategory {
  BOOKS
  LAPTOP
  PROJECTOR
  CALCULATOR
  CAMERA
  CYCLE
  FURNITURE
  OTHER
}

enum RentalPricingType {
  DAILY
  WEEKLY
  MONTHLY
}

enum RentalItemStatus {
  AVAILABLE
  RENTED
}

model RentalItem {
  id             Int               @id @default(autoincrement())
  title          String
  description    String?
  category       RentalCategory
  imageUrl       String?
  pricingType    RentalPricingType @default(DAILY)
  price          Int
  securityDeposit Int              @default(0)
  status         RentalItemStatus  @default(AVAILABLE)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  ownerId        Int
  owner          User              @relation("RentalOwner", fields: [ownerId], references: [id])

  collegeId      Int
  college        College           @relation(fields: [collegeId], references: [id])

  bookings       RentalBooking[]
}
enum RentalBookingStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  RETURNED
  OVERDUE
}
model RentalBooking {
  id             Int                 @id @default(autoincrement())
  startDate      DateTime
  expectedReturnDate DateTime
  actualStartDate    DateTime?
  actualReturnDate   DateTime?
  status         RentalBookingStatus @default(PENDING)
  otp String?
  rentAmount     Int
  securityDeposit Int
  lateFee        Int                 @default(0)
  couponUsed     Boolean             @default(false)
  platformAbsorbed Int               @default(0)

  createdAt      DateTime            @default(now())

  renterId       Int
  renter         User                @relation("RentalRenter", fields: [renterId], references: [id])

  itemId         Int
  item           RentalItem          @relation(fields: [itemId], references: [id])
}
enum PlanType {
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

model Payment {
  id              Int           @id @default(autoincrement())
  razorpayOrderId String        @unique
  razorpayPaymentId String?
  amount          Int
  planType        PlanType
  status          PaymentStatus @default(CREATED)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  userId          Int
  user            User          @relation(fields: [userId], references: [id])
}
model ChatSession {
  id        Int      @id @default(autoincrement())
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  messages  AiMessage[]
}

enum MessageRole {
  USER
  ASSISTANT
}

model AiMessage {
  id        Int         @id @default(autoincrement())
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  sessionId Int
  session   ChatSession @relation(fields: [sessionId], references: [id])
}
enum TestDifficulty {
  EASY
  MEDIUM
  HARD
}

model Test {
  id             Int            @id @default(autoincrement())
  title          String
  topic          String
  difficulty     TestDifficulty @default(MEDIUM)
  durationMinutes Int           @default(30)
  negativeMarking Float         @default(0)
  isPremium      Boolean        @default(false)
  price          Int?

  createdAt      DateTime       @default(now())

  createdById    Int
  createdBy      User           @relation(fields: [createdById], references: [id])

  collegeId      Int
  college        College        @relation(fields: [collegeId], references: [id])

  courseId       Int
  course         Course         @relation(fields: [courseId], references: [id])

  semesterId     Int
  semester       Semester       @relation(fields: [semesterId], references: [id])

  subjectId      Int?
  subject        Subject?       @relation(fields: [subjectId], references: [id])

  questions      TestQuestion[]
  attempts       TestAttempt[]
  purchases      TestPurchase[]
}

model TestQuestion {
  id            Int      @id @default(autoincrement())
  questionText  String
  options       Json
  correctIndex  Int

  testId        Int
  test          Test     @relation(fields: [testId], references: [id])
  answers TestAnswer[]
}

model TestAttempt {
  id           Int       @id @default(autoincrement())
  score        Int       @default(0)
  totalQuestions Int
  startedAt    DateTime  @default(now())
  submittedAt  DateTime?

  userId       Int
  user         User      @relation(fields: [userId], references: [id])

  testId       Int
  test         Test      @relation(fields: [testId], references: [id])

  answers      TestAnswer[]
}

model TestAnswer {
  id             Int      @id @default(autoincrement())
  selectedIndex  Int?
  isCorrect      Boolean  @default(false)

  attemptId      Int
  attempt        TestAttempt @relation(fields: [attemptId], references: [id])

  questionId     Int
  question       TestQuestion @relation(fields: [questionId], references: [id])
}

model TestPurchase {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  testId    Int
  test      Test     @relation(fields: [testId], references: [id])

  @@unique([userId, testId])
}
model Feedback {
  id        Int      @id @default(autoincrement())
  message   String
  page      String?
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}
enum ReportType {
  LISTING
  LOST_FOUND_ITEM
  NOTE
  USER
}

model Report {
  id         Int        @id @default(autoincrement())
  type       ReportType
  targetId   Int
  reason     String
  createdAt  DateTime   @default(now())
  resolved   Boolean    @default(false)

  reportedById Int
  reportedBy   User     @relation(fields: [reportedById], references: [id])
}
model PasswordResetOTP {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
enum RequestStatus {
  OPEN
  FULFILLED
}

model ResourceRequest {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  status      RequestStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  fulfilledAt DateTime?

  requestedById Int
  requestedBy   User        @relation("RequestedResources", fields: [requestedById], references: [id])

  collegeId   Int
  college     College       @relation(fields: [collegeId], references: [id])

  fulfilledNoteId Int?
  fulfilledNote   Note?     @relation(fields: [fulfilledNoteId], references: [id])
}
model UserDevice {
  id         Int      @id @default(autoincrement())

  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fcmToken   String   @unique
  platform   String
  deviceName String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}
model TimetableSlot {
  id          Int      @id @default(autoincrement())
  dayOfWeek   Int      // 0 = Sunday, 1 = Monday ... 6 = Saturday
  startTime   String   // "09:00" format (24hr)
  endTime     String   // "10:00" format
  subjectName String
  room        String?
  facultyName String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])

  semesterId  Int
  semester    Semester @relation(fields: [semesterId], references: [id])

  collegeId   Int
  college     College  @relation(fields: [collegeId], references: [id])
}