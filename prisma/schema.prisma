generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model University {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  city      String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  colleges  College[]
  notes     Note[]
}

model College {
  id           Int      @id @default(autoincrement())
  name         String
  code         String
  city         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  universityId Int
  university   University   @relation(fields: [universityId], references: [id])

  departments  Department[]
  students     User[]
  admin        User?   @relation("CollegeAdmin")
  notices Notice[]
  events Event[]
  listings Listing[]
  @@unique([universityId, code])
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collegeId Int
  college   College   @relation(fields: [collegeId], references: [id])

  courses   Course[]
  students  User[]
  notices Notice[]

  @@unique([collegeId, code])
}

model Course {
  id           Int      @id @default(autoincrement())
  name         String
  code         String
  durationYrs  Int      @default(4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  semesters    Semester[]
  students     User[]
  notes        Note[]
  notices Notice[]

  @@unique([departmentId, code])
}

model Semester {
  id        Int      @id @default(autoincrement())
  number    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id])

  subjects  Subject[]
  students  User[]
  notes     Note[]
  notices Notice[]
  @@unique([courseId, number])
}

model Subject {
  id         Int      @id @default(autoincrement())
  name       String
  code       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  semesterId Int
  semester   Semester @relation(fields: [semesterId], references: [id])

  notes      Note[]

  @@unique([semesterId, code])
}

enum UserRole {
  STUDENT
  FACULTY
  ADMIN
  SUPER_ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STUDENT)

  phone        String?
  avatarUrl    String?

  isPremium    Boolean  @default(false)
  premiumUntil DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Student ke liye — kis college/dept/course/semester me hai
  collegeId    Int?
  college      College?    @relation(fields: [collegeId], references: [id])

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  courseId     Int?
  course       Course?     @relation(fields: [courseId], references: [id])

  semesterId   Int?
  semester     Semester?   @relation(fields: [semesterId], references: [id])

  // Admin ke liye — sirf ek college manage karta hai
  managedCollegeId Int?    @unique
  managedCollege   College? @relation("CollegeAdmin", fields: [managedCollegeId], references: [id])

  uploadedNotes Note[] @relation("UploadedNotes")
  ratings   Rating[]
  bookmarks Bookmark[]
  comments  Comment[]
  postedNotices Notice[] @relation("PostedNotices")
  createdEvents Event[] @relation("CreatedEvents")
  eventRegistrations EventRegistration[]
  sellerListings Listing[] @relation("SellerListings")
  wishlist       Wishlist[]
  sentMessages   ChatMessage[] @relation("SentMessages")
  buyerOrders    Order[] @relation("BuyerOrders")
  coupons Coupon[]
}

enum NoteCategory {
  NOTES
  ASSIGNMENT
  LAB_RECORD
  PREVIOUS_YEAR_PAPER
  BOOK
  PRESENTATION
  PRACTICAL_FILE
  QUESTION_BANK
  FACULTY_NOTES
  VIVA_QUESTIONS
  PROJECT
  SYLLABUS
  OTHERS
}
model Note {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  fileType    String
  category    NoteCategory @default(NOTES)
  unit        String?
  isPremium   Boolean  @default(false)

  views       Int      @default(0)
  downloads   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  uploadedById Int
  uploadedBy   User     @relation("UploadedNotes", fields: [uploadedById], references: [id])

  universityId Int
  university   University @relation(fields: [universityId], references: [id])

  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])

  semesterId  Int
  semester    Semester @relation(fields: [semesterId], references: [id])

  subjectId   Int?
  subject     Subject? @relation(fields: [subjectId], references: [id])
  ratings   Rating[]
  bookmarks Bookmark[]
  comments  Comment[]
  coupons Coupon[]
}
model Coupon {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  discountPercent Int      @default(5)
  isUsed          Boolean  @default(false)
  usedAt          DateTime?
  createdAt       DateTime @default(now())

  ownerId         Int
  owner           User     @relation(fields: [ownerId], references: [id])

  sourceNoteId    Int?
  sourceNote      Note?    @relation(fields: [sourceNoteId], references: [id])
}
model Rating {
  id        Int      @id @default(autoincrement())
  value     Int
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  noteId    Int
  note      Note     @relation(fields: [noteId], references: [id])

  @@unique([userId, noteId])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  noteId    Int
  note      Note     @relation(fields: [noteId], references: [id])

  @@unique([userId, noteId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  noteId    Int
  note      Note     @relation(fields: [noteId], references: [id])
}
model Notice {
  id           Int       @id @default(autoincrement())
  title        String
  content      String
  attachmentUrl String?

  isPinned     Boolean   @default(false)
  isArchived   Boolean   @default(false)
  publishAt    DateTime  @default(now())

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  postedById   Int
  postedBy     User      @relation("PostedNotices", fields: [postedById], references: [id])

  collegeId    Int
  college      College   @relation(fields: [collegeId], references: [id])

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  courseId     Int?
  course       Course?   @relation(fields: [courseId], references: [id])

  semesterId   Int?
  semester     Semester? @relation(fields: [semesterId], references: [id])
}
enum EventType {
  FEST
  HACKATHON
  SEMINAR
  SPORTS
  WORKSHOP
  COMPETITION
  OTHER
}

model Event {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  type          EventType @default(OTHER)
  venue         String?
  bannerUrl     String?

  eventDate     DateTime
  registrationDeadline DateTime?
  seatLimit     Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdById   Int
  createdBy     User      @relation("CreatedEvents", fields: [createdById], references: [id])

  collegeId     Int
  college       College   @relation(fields: [collegeId], references: [id])

  registrations EventRegistration[]
}

model EventRegistration {
  id          Int      @id @default(autoincrement())
  registeredAt DateTime @default(now())
  qrCode      String   @unique
  attended    Boolean  @default(false)

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  eventId     Int
  event       Event    @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}
enum ListingType {
  SELL
  EXCHANGE
}

enum ListingCategory {
  BOOKS
  LAPTOP
  CYCLE
  CALCULATOR
  FURNITURE
  HOSTEL_ITEMS
  ELECTRONICS
  OTHER
}

enum ListingStatus {
  AVAILABLE
  SOLD
  RESERVED
}

model Listing {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  category    ListingCategory
  type        ListingType     @default(SELL)
  price       Int?
  imageUrl    String?
  location    String?
  status      ListingStatus   @default(AVAILABLE)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sellerId    Int
  seller      User            @relation("SellerListings", fields: [sellerId], references: [id])

  collegeId   Int
  college     College         @relation(fields: [collegeId], references: [id])

  wishlistedBy Wishlist[]
  messages     ChatMessage[]
  orders       Order[]
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  senderId  Int
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])

  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Order {
  id          Int      @id @default(autoincrement())
  finalPrice  Int?
  createdAt   DateTime @default(now())

  buyerId     Int
  buyer       User     @relation("BuyerOrders", fields: [buyerId], references: [id])

  listingId   Int
  listing     Listing  @relation(fields: [listingId], references: [id])
}